# GitHub Personal Access Token — https://github.com/settings/tokens
# Required for GitHub GraphQL API (client-side).
NEXT_PUBLIC_GITHUB_TOKEN=your-github-personal-access-token

# Sentry Error Tracking Configuration
# Sentry DSN (Data Source Name) - Get from: https://arnob-mahmuds-org.sentry.io/settings/projects/stock-inventory/keys/
# NOTE: This is different from Sentry API Key - DSN is used for client-side error tracking
# Format: https://<key>@<org>.ingest.sentry.io/<project_id>
SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Sentry org/project slugs (from wizard: --org arnob-mahmuds-org --project github-dev-explorer)
SENTRY_ORG="your-org-slug-here"
SENTRY_PROJECT="your-project-slug-here"

# Sentry Auth Token — required for source map upload at build time (next build)
# Generate at: https://arnob-mahmuds-org.sentry.io/settings/auth-tokens/ → Create Auth Token
# Scopes needed: project:releases, org:read
SENTRY_AUTH_TOKEN="your-auth-token-here"
